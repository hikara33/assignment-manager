// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  email    String @unique
  password String

  name String
  role UserRole @default(STUDENT)

  groups UserGroup[]

  refreshTokens RefreshToken[] @relation("user-tokens")
  assignments   Assignment[]   @relation("user-assignemnts")
  invites       GroupInvite[]  @relation("user-invites")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id String @id @default(uuid())

  hashToken String

  userId String @map("user_id")
  user   User   @relation("user-tokens", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([userId])
  @@map("refresh-tokens")
}

model Assignment {
  id String @id @default(uuid())

  title       String
  description String?

  dueDay DateTime
  status AssignmentStatus @default(PENDING)

  userId String @map("user_id")
  user   User   @relation("user-assignemnts", fields: [userId], references: [id])

  subjectId String  @map("subject_id")
  subject   Subject @relation("subject-assignments", fields: [subjectId], references: [id])

  groupId String? @map("group_id")
  group   Group?  @relation("group-assignemnts", fields: [groupId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@unique([title, subjectId])
  @@map("assignments")
}

model Subject {
  id String @id @default(ulid())

  name        String  @unique
  description String?

  assignments Assignment[] @relation("subject-assignments")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@map("subjects")
}

model Group {
  id String @id @default(uuid())

  name String @unique

  assignments Assignment[]  @relation("group-assignemnts")
  invites     GroupInvite[] @relation("group_invites")
  members     UserGroup[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@map("groups")
}

model UserGroup {
  userId  String @map("user_id")
  groupId String @map("group_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  role GroupRole @default(MEMBER)

  @@id([userId, groupId])
  @@map("users_groups")
}

model GroupInvite {
  id String @id @default(uuid())

  email String
  token String? @unique

  groupId String @map("group_id")
  group   Group  @relation("group_invites", fields: [groupId], references: [id], onDelete: Cascade)

  invitedById String @map("invited_by_id")
  invitedBy   User   @relation("user-invites", fields: [invitedById], references: [id], onDelete: Cascade)

  status InviteStatus @default(PENDING)

  expiresAt  DateTime
  usedAt DateTime?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([groupId])
  @@map("group_invites")
}

enum UserRole {
  ADMIN
  STUDENT
}

enum AssignmentStatus {
  PENDING
  COMPLETED
  OVERDUE
  ARCHIVED
}

enum GroupRole {
  OWNER
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}
